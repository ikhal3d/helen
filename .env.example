# ============================================================
# Helen Skincare — environment variables
# ============================================================
# Copy this file to `.env.local` for development and add real values.
# Never commit `.env.local` or anything containing real keys.
# ============================================================

# --- Stripe ----------------------------------------------------
# Publishable key (safe for the browser). Get it from:
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Checkout endpoint. For a static GitHub Pages deploy this
# must point at a small serverless function you host (Vercel,
# Netlify, AWS Lambda, Cloudflare Worker) that creates a Stripe
# Checkout session and returns its URL. See README "Payments".
NEXT_PUBLIC_STRIPE_CHECKOUT_ENDPOINT=https://your-api.example.com/api/create-checkout-session

# --- PayPal ----------------------------------------------------
# Sandbox or live client ID from:
# https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=test

# --- Site ------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://helenskincare.com
NEXT_PUBLIC_CURRENCY=AUD
NEXT_PUBLIC_CONTACT_EMAIL=hello@helenskincare.com

# --- GitHub Pages (CI only) -----------------------------------
# Set automatically by the deploy workflow. Do not set locally.
# GITHUB_PAGES=true
